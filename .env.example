# ======================================================================
# AI 报价网 W1 - 环境变量模板
# ======================================================================
# 使用方法: 复制为 .env 并填入真实 key
#   cp .env.example .env
# .env 文件已被 .gitignore 排除,严禁入代码
# ======================================================================

# agnes-2.0-flash API 配置
AGNES_API_KEY=sk-REPLACE_ME_WITH_YOUR_AGNES_KEY
AGNES_BASE_URL=https://apihub.agnes-ai.com/v1
AGNES_MODEL=agnes-2.0-flash

# 服务配置
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false

# 限流配置(全局默认 QPS,适用于 /api/quote)
RATE_LIMIT_QPS=5

# ===== W2 调整版 =====
# 管理接口鉴权 (POST /api/admin/reload-prices, GET /api/admin/stats)
# 建议: 32 位随机字符串,严禁跟 AGNES_API_KEY 相同
ADMIN_TOKEN=wj-quote-admin-CHANGE-ME
# 登录验证码 (W2 临时固定,生产环境接短信网关)
LOGIN_FIXED_CODE=123456
# 登录/留资 限流(防爆破)
LOGIN_RATE_QPS=1
LEAD_RATE_QPS=1

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
