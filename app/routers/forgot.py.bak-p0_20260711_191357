"""
忘记密码 - V3

POST /api/forgot/reset - 一步重置密码
  - 输入: mobile + new_password
  - 前端图验已通过 (后端不再做图验,信任前端)
  - bcrypt 重写 password_hash
  - 限流 1 QPS (防爆破)
  - 限速: 同手机号 60 秒内最多 3 次 (防脚本刷)
"""
from __future__ import annotations

import logging
import re
import time

import bcrypt
from fastapi import APIRouter, HTTPException, status
from pydantic import BaseModel, Field

from app.models.database import SessionLocal, User
from app.utils.rate_limit import get_login_limiter

router = APIRouter(prefix="/api/forgot", tags=["forgot"])
logger = logging.getLogger(__name__)

MOBILE_RE = re.compile(r"^1[3-9]\d{9}$")

# 内存级限速: mobile -> [timestamps]
_reset_history: dict[str, list[float]] = {}
_RESET_WINDOW = 60.0
_RESET_MAX = 3


def _check_reset_rate(mobile: str) -> None:
    now = time.monotonic()
    hist = _reset_history.setdefault(mobile, [])
    # 清理窗口外
    while hist and now - hist[0] > _RESET_WINDOW:
        hist.pop(0)
    if len(hist) >= _RESET_MAX:
        raise HTTPException(
            status_code=status.HTTP_429_TOO_MANY_REQUESTS,
            detail={"error": "rate_limited", "hint": f"该手机号 {_RESET_WINDOW} 秒内最多 {_RESET_MAX} 次重置,请稍后再试"},
        )


class ResetRequest(BaseModel):
    mobile: str = Field(..., min_length=11, max_length=11)
    new_password: str = Field(..., min_length=6, max_length=20)


class ResetResponse(BaseModel):
    success: bool
    user_id: int
    mobile: str


@router.post("/reset", response_model=ResetResponse)
async def reset_password(req: ResetRequest):
    """
    一步重置密码 (前端图验已通过)
    """
    if not MOBILE_RE.match(req.mobile or ""):
        raise HTTPException(
            status_code=status.HTTP_422_UNPROCESSABLE_ENTITY,
            detail={"error": "invalid_mobile", "hint": "请输入 11 位有效手机号"},
        )
    if not req.new_password or len(req.new_password) < 6 or len(req.new_password) > 20:
        raise HTTPException(
            status_code=status.HTTP_422_UNPROCESSABLE_ENTITY,
            detail={"error": "invalid_password", "hint": "密码 6-20 位"},
        )

    # 全局限流 1 QPS
    result = get_login_limiter().acquire()
    if not result.allowed:
        raise HTTPException(
            status_code=status.HTTP_429_TOO_MANY_REQUESTS,
            detail={"error": "rate_limited", "hint": "操作过于频繁,请稍后再试", "retry_after": result.retry_after},
        )

    # 同手机号窗口限速
    _check_reset_rate(req.mobile)
    _reset_history[req.mobile].append(time.monotonic())

    db = SessionLocal()
    try:
        user = db.query(User).filter(User.mobile == req.mobile).first()
        if not user:
            # 故意返回通用错误,防枚举
            raise HTTPException(
                status_code=status.HTTP_404_NOT_FOUND,
                detail={"error": "user_not_found", "hint": "该手机号未注册"},
            )

        # bcrypt 重写密码
        user.password_hash = bcrypt.hashpw(req.new_password.encode("utf-8"), bcrypt.gensalt(rounds=10)).decode("utf-8")
        db.commit()
        db.refresh(user)
        logger.info("密码重置 mobile=%s user_id=%s", req.mobile, user.id)

        return ResetResponse(success=True, user_id=user.id, mobile=user.mobile)
    finally:
        db.close()
