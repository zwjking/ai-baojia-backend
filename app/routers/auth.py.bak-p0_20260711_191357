"""
认证接口 - V3 注册/登录

POST /api/register - 手机号+密码注册
  - 密码用 bcrypt 散列存 password_hash
  - 同手机号不允许重复注册
  - 限流 1 QPS
  - 注册成功自动返回 token + user_id (无需二次登录)

POST /api/login - 手机号+密码登录 (优先) / 验证码登录 (兜底)
  - 如果用户有 password_hash, 走密码校验
  - 如果用户没 password_hash (老用户), 走验证码 123456
  - 限流 1 QPS
"""
from __future__ import annotations

import logging
import os
import re
import uuid

import bcrypt
from fastapi import APIRouter, HTTPException, status
from pydantic import BaseModel, Field

from app.models.database import SessionLocal, User
from app.utils.rate_limit import get_login_limiter

router = APIRouter(prefix="/api", tags=["auth"])
logger = logging.getLogger(__name__)


# ============== 通用校验 ==============
MOBILE_RE = re.compile(r"^1[3-9]\d{9}$")


def _validate_mobile(mobile: str) -> None:
    if not MOBILE_RE.match(mobile or ""):
        raise HTTPException(
            status_code=status.HTTP_422_UNPROCESSABLE_ENTITY,
            detail={"error": "invalid_mobile", "hint": "请输入 11 位有效手机号"},
        )


def _validate_password(password: str) -> None:
    if not password or len(password) < 6 or len(password) > 20:
        raise HTTPException(
            status_code=status.HTTP_422_UNPROCESSABLE_ENTITY,
            detail={"error": "invalid_password", "hint": "密码 6-20 位,字母+数字组合更佳"},
        )


# ============== Pydantic 模型 ==============
class RegisterRequest(BaseModel):
    mobile: str = Field(..., min_length=11, max_length=11, description="手机号")
    password: str = Field(..., min_length=6, max_length=20, description="密码 6-20 位")


class LoginRequest(BaseModel):
    mobile: str = Field(..., min_length=11, max_length=11, description="手机号")
    password: str = Field(default=None, min_length=6, max_length=20, description="密码(优先)")
    code: str = Field(default=None, min_length=6, max_length=6, description="验证码(兜底,测试固定 123456)")


class AuthResponse(BaseModel):
    token: str
    user_id: int
    mobile: str
    has_password: bool


# ============== /api/register ==============
@router.post("/register", response_model=AuthResponse)
async def register(req: RegisterRequest):
    """
    手机号+密码注册

    行为:
    - 同手机号已注册 -> 409 Conflict
    - 密码 bcrypt 散列存 password_hash
    - 自动返回 token (无需二次登录)
    """
    _validate_mobile(req.mobile)
    _validate_password(req.password)

    # 限流
    result = get_login_limiter().acquire()
    if not result.allowed:
        raise HTTPException(
            status_code=status.HTTP_429_TOO_MANY_REQUESTS,
            detail={"error": "rate_limited", "hint": "操作过于频繁,请稍后再试", "retry_after": result.retry_after},
        )

    # bcrypt 散列
    pwd_hash = bcrypt.hashpw(req.password.encode("utf-8"), bcrypt.gensalt(rounds=10)).decode("utf-8")

    db = SessionLocal()
    try:
        existing = db.query(User).filter(User.mobile == req.mobile).first()
        if existing:
            if existing.password_hash:
                raise HTTPException(
                    status_code=status.HTTP_409_CONFLICT,
                    detail={"error": "mobile_exists", "hint": "该手机号已注册,请直接登录"},
                )
            # 老用户无密码 -> 补设密码(升级为密码用户)
            existing.password_hash = pwd_hash
            db.commit()
            db.refresh(existing)
            user = existing
            logger.info("老用户补设密码 mobile=%s user_id=%s", req.mobile, user.id)
        else:
            user = User(mobile=req.mobile, password_hash=pwd_hash)
            db.add(user)
            db.commit()
            db.refresh(user)
            logger.info("新用户注册 mobile=%s user_id=%s", req.mobile, user.id)

        return AuthResponse(
            token=str(uuid.uuid4()),
            user_id=user.id,
            mobile=user.mobile,
            has_password=True,
        )
    finally:
        db.close()


# ============== /api/login ==============
@router.post("/login", response_model=AuthResponse)
async def login(req: LoginRequest):
    """
    登录 - 优先密码 / 兜底验证码

    行为:
    - 用户有 password_hash + 提供 password -> bcrypt 校验
    - 用户有 password_hash + 没提供 password -> 401 提示需要密码
    - 用户没 password_hash (老用户) -> 走验证码 123456
    - 限流 1 QPS
    """
    _validate_mobile(req.mobile)

    # 限流
    result = get_login_limiter().acquire()
    if not result.allowed:
        raise HTTPException(
            status_code=status.HTTP_429_TOO_MANY_REQUESTS,
            detail={"error": "rate_limited", "hint": "登录过于频繁,请稍后再试", "retry_after": result.retry_after},
        )

    db = SessionLocal()
    try:
        user = db.query(User).filter(User.mobile == req.mobile).first()
        if not user:
            raise HTTPException(
                status_code=status.HTTP_404_NOT_FOUND,
                detail={"error": "user_not_found", "hint": "该手机号未注册,请先注册账号"},
            )

        # 已设密码 -> 必须走密码
        if user.password_hash:
            if not req.password:
                raise HTTPException(
                    status_code=status.HTTP_401_UNAUTHORIZED,
                    detail={"error": "password_required", "hint": "该账号已设密码,请用密码登录"},
                )
            try:
                ok = bcrypt.checkpw(req.password.encode("utf-8"), user.password_hash.encode("utf-8"))
            except Exception as e:
                logger.warning("bcrypt 校验异常 mobile=%s err=%s", req.mobile, e)
                ok = False
            if not ok:
                raise HTTPException(
                    status_code=status.HTTP_401_UNAUTHORIZED,
                    detail={"error": "wrong_password", "hint": "密码错误,请重试"},
                )
            logger.info("用户密码登录 mobile=%s user_id=%s", req.mobile, user.id)
            return AuthResponse(
                token=str(uuid.uuid4()),
                user_id=user.id,
                mobile=user.mobile,
                has_password=True,
            )

        # 老用户没密码 -> 验证码兜底
        fixed_code = os.getenv("LOGIN_FIXED_CODE", "123456")
        if not req.code or req.code != fixed_code:
            raise HTTPException(
                status_code=status.HTTP_401_UNAUTHORIZED,
                detail={"error": "invalid_code", "hint": f"验证码错误 (测试固定码: {fixed_code})"},
            )
        logger.info("老用户验证码登录 mobile=%s user_id=%s", req.mobile, user.id)
        return AuthResponse(
            token=str(uuid.uuid4()),
            user_id=user.id,
            mobile=user.mobile,
            has_password=False,
        )
    finally:
        db.close()
